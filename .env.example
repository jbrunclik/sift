# Gemini API key (required for scoring)
GEMINI_API_KEY=

# Reddit API credentials (required for Reddit source)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=news-aggregator/0.1

# YouTube Data API key (optional, RSS works without it)
YOUTUBE_API_KEY=

# Database path (default: data/news.db)
DATABASE_PATH=data/news.db

# Server settings
HOST=0.0.0.0
PORT=8000
DEBUG=false
